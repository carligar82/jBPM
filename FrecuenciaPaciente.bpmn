    <bpmn2:scriptTask id="_007A4591-4AEC-43AD-9C87-EDE1A7D64136" name="Dato frecuencia" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Dato frecuencia]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_700A4DC6-9BC5-4B01-8FC9-AE88F0E14F6F</bpmn2:incoming>
      <bpmn2:outgoing>_7A6A3CBD-DA10-46D0-8BF6-C40F31E863DF</bpmn2:outgoing>
      <bpmn2:script><![CDATA[if ((frec.getFrecuencia()>=pac.getFminima()) && (frec.getFrecuencia()<=pac.getFmaxima()))
{
 System.out.println("Frecuencia cardiaca : "+frec.getFrecuencia());
 System.out.println("Frecuencia normal. Rango frecuencia: "+pac.getFminima()+"-"+pac.getFmaxima());
}
else
{
 System.out.println("Frecuencia cardiaca : "+frec.getFrecuencia());
 System.out.println("Frecuencia anormal. Rango frecuencia: "+pac.getFminima()+"-"+pac.getFmaxima());
}]]></bpmn2:script>
    </bpmn2:scriptTask>
