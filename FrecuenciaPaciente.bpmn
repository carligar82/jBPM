    <bpmn2:scriptTask id="_1C42C818-250A-4548-8584-56BAB76B3046" name="SET" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[SET]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_BD68FBA2-5EBF-4FAA-B7FE-4CCA001665CB</bpmn2:incoming>
      <bpmn2:outgoing>_2CF9A9BC-B0F1-4244-909C-353482ADAE6D</bpmn2:outgoing>
      <bpmn2:script><![CDATA[if (pac.getFminima()==null) 
{
 pac.setFminima(60);
 pac.setFmaxima(140);
}
if ((frec.getFrecuencia()>=pac.getFminima()) && (frec.getFrecuencia()<=pac.getFmaxima()))
{
 pac.setEnfermo(false);
}
else
{
pac.setEnfermo(true);
}
]]></bpmn2:script>
    </bpmn2:scriptTask>
